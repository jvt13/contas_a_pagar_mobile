{
  "expo": {
    "name": "OrganizeContas",
    "slug": "controle_contas",
    "version": "1.0.8",
    "orientation": "portrait",
    "icon": "./assets/img/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/img/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "contaspagar",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zevitor.controle_contas"
    },
    "android": {
      "versionCode": 10,
      "package": "com.zevitor.controle_contas",
      "adaptiveIcon": {
        "foregroundImage": "./assets/img/icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/img/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "61b34e92-c4e6-425c-8bd2-3a8f8496c082"
      }
    },
    "plugins": [
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ]
  }
}