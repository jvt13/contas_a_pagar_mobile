# Porta da API (padrão 3100 se não definir PORT)
PORT=3100

# PostgreSQL — API (conexao.js) e npm run backup
# Copie para .env e ajuste. Nunca commite .env.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=contas_a_pagar

# Alternativa equivalente:
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_DB=contas_a_pagar
