{
  "cli": {
    "version": ">= 3.9.1",
    "requireCommit": false,
    "appVersionSource": "local"
  },
  "build": {
    "preview-local": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.15.100:3100"
      }
    },
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-contas.srv-jvt.com"
      },
      "distribution": "internal"
    },
    "production-apk": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-contas.srv-jvt.com"
      },
      "distribution": "internal"
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-contas.srv-jvt.com"
      },
      "distribution": "store"
    }
  }
}
